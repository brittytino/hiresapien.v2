# ============================================================
# HIRESAPIEN - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your credentials.
# The app runs WITHOUT these in development — but data will NOT
# persist and AI evaluation will fall back to keyword matching.
# ============================================================

# --- MongoDB Atlas ---
# How to get this:
# 1. Go to https://cloud.mongodb.com and create a free account
# 2. Create a free M0 cluster (takes ~2 minutes)
# 3. Under "Database Access", create a user with read/write access
# 4. Under "Network Access", add your IP (or 0.0.0.0/0 for any)
# 5. Click "Connect" → "Connect your application" → copy the URI
# 6. Replace <username>, <password>, <dbname> in the URI below
MONGO_URI= mongodb+srv://thiganthworkspace02_db_user:5EjPr1gvUwBJG8OM@cluster0.lw8lapo.mongodb.net/
# --- Google Gemini API Key ---
# How to get this:
# 1. Go to https://aistudio.google.com
# 2. Sign in with your Google account
# 3. Click "Get API Key" → "Create API key"
# 4. Copy and paste it below
# NOTE: Free tier is sufficient for this app (60 requests/minute)
GEMINI_API_KEY=your_gemini_api_key_here

# --- App Display Name (no change needed) ---
NEXT_PUBLIC_APP_NAME=Hiresapien
